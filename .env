# Application
APP_NAME="AI Commerce Assistant"
APP_ENV=development
DEBUG=true
PORT=8000

# LLM (Ollama yerel model)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Embedding modeli (sentence-transformers)
EMBEDDING_MODEL=nomic-embed-text

# PostgreSQL (Docker)
POSTGRES_USER=aicommerce
POSTGRES_PASSWORD=changeme123
POSTGRES_DB=aicommerce_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://aicommerce:changeme123@localhost:5432/aicommerce_db

# Cache (Redis)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379


# ELK log forwarding (local app -> logstash)
LOGSTASH_HOST=localhost
LOGSTASH_PORT=5514

# QDrand Vector DB Configuration
QDRAND_URL=localhost
QDRAND_COLLECTION=products
QDRAND_PORT=6333